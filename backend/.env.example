# =========================================================
# APP / ENVIRONMENT
# =========================================================
APP_NAME=backend
APP_ENV=local
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=/api
LOG_LEVEL=INFO

# CORS: allowed browser origins (JSON array). Defaults in code include localhost:3000/5173.
# Example production:
# CORS_ORIGINS=["https://app.example.com"]

# =========================================================
# AZURE OPENAI
# =========================================================
AZURE_OPENAI_ENDPOINT="..."
AZURE_OPENAI_API_KEY="..."
AZURE_OPENAI_API_VERSION="2024-10-21"

# Default routing
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-5-mini"
AZURE_OPENAI_REASONING_DEPLOYMENT="gpt-5"
AZURE_OPENAI_STAGE3_CHAT_DEPLOYMENT="gpt-5-mini"

# Fill later once embedding deployment is created
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"

# =========================================================
# AZURE AI DOCUMENT INTELLIGENCE
# =========================================================
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="..."
AZURE_DOCUMENT_INTELLIGENCE_KEY="..."

# =========================================================
# AZURE AI SEARCH
# =========================================================
AZURE_SEARCH_ENDPOINT="..."
AZURE_SEARCH_API_KEY="..."
AZURE_SEARCH_INDEX_NAME="sdlc_knowledge_index"

# =========================================================
# AZURE BLOB STORAGE
# =========================================================
AZURE_STORAGE_CONNECTION_STRING=".."
AZURE_STORAGE_CONTAINER_NAME="aipdd"

# Root folder inside the shared container
AZURE_STORAGE_ROOT_PREFIX="sahil_storage"

# Virtual folder structure inside the same container
AZURE_BLOB_PATH_RAW_DOCUMENTS="raw-documents"
AZURE_BLOB_PATH_INGESTION_PARSED="ingestion/parsed"
AZURE_BLOB_PATH_INGESTION_ENRICHED="ingestion/enriched"
AZURE_BLOB_PATH_INGESTION_CHUNKS="ingestion/chunks"
AZURE_BLOB_PATH_INGESTION_VALIDATION="ingestion/validation"
AZURE_BLOB_PATH_INGESTION_METRICS="ingestion/metrics"

AZURE_BLOB_PATH_TEMPLATES_STANDARD=templates/standard
AZURE_BLOB_PATH_TEMPLATES_CUSTOM=templates/custom
AZURE_BLOB_PATH_TEMPLATES_LAYOUTS=templates/layouts
AZURE_BLOB_PATH_TEMPLATES_SHELLS=templates/shells

AZURE_BLOB_PATH_GENERATED_DOCUMENTS=generated/documents
AZURE_BLOB_PATH_GENERATED_DIAGRAMS=generated/diagrams
AZURE_BLOB_PATH_GENERATED_EXPORTS=generated/exports

AZURE_BLOB_PATH_OBSERVABILITY_LOGS=observability/logs
AZURE_BLOB_PATH_OBSERVABILITY_USAGE=observability/usage
AZURE_BLOB_PATH_OBSERVABILITY_COSTS=observability/costs

AZURE_BLOB_PATH_TEMP=temp

# =========================================================
# KROKI
# =========================================================
KROKI_BASE_URL=http://localhost:8000

# =========================================================
# OBSERVABILITY / PIPELINE DEFAULTS
# =========================================================
PRICING_REGISTRY_PATH=backend/config/pricing_registry.json
MAX_PROMPT_TOKENS=3000
MAX_GENERATION_RETRIES=2
MAX_DIAGRAM_FIX_RETRIES=3