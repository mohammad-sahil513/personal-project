# Browser requests go to same origin + this path (Vite dev server proxies /api → backend).
# Default in code is `/api` if unset.
VITE_API_BASE=/api

# Where Vite forwards /api in dev (must match backend APP_HOST / APP_PORT). Not bundled into the client.
# BACKEND_ORIGIN=http://127.0.0.1:8000
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
