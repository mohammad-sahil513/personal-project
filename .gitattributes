# Use LF in the repository and working tree for text files (consistent on all OSes;
# avoids "LF will be replaced by CRLF" noise on Windows with autocrlf).
* text=auto eol=lf

# Windows-only scripts keep CRLF if you add them later
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
